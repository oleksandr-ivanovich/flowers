# --- Backend ---
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=720
CORS_ORIGINS=http://localhost,http://localhost:5173

# --- PostgreSQL ---
POSTGRES_DB=marina
POSTGRES_USER=marina
POSTGRES_PASSWORD=change-me
# For api container (hostname "db" is the compose service):
DATABASE_URL=postgresql+psycopg://marina:change-me@db:5432/marina

# --- Deployment ---
# Domain that Caddy will serve with automatic TLS. Use :80 for local HTTP only.
DOMAIN=:80
